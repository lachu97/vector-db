{
  "name": "vectordb-client",
  "version": "0.1.0",
  "description": "TypeScript/JavaScript SDK for the VectorDB REST API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["vector", "database", "embeddings", "semantic-search", "rag", "ai"],
  "license": "MIT",
  "author": "lachu97",
  "homepage": "https://lachu97.github.io/vector-db/",
  "repository": {
    "type": "git",
    "url": "https://github.com/lachu97/vector-db.git",
    "directory": "sdk/typescript"
  },
  "bugs": {
    "url": "https://github.com/lachu97/vector-db/issues"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "jest-environment-node": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
